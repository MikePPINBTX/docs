{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "1nSpecT Help Center",
  "colors": {
    "primary": "#3232A8",
    "light": "#6CDD33",
    "dark": "#3232A8"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@1nspect.app"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open App",
      "href": "https://app.1nspect.app"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "1nSpecT Platform",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "1nspect/getting-started/account-and-branding",
              "1nspect/getting-started/build-your-first-template",
              "1nspect/getting-started/create-your-first-order",
              "1nspect/getting-started/mobile-inspection-walkthrough",
              "1nspect/getting-started/generate-your-first-report"
            ]
          },
          {
            "group": "Features",
            "pages": [
              "1nspect/features/ai-features",
              "1nspect/features/communications",
              "1nspect/features/contracts"
            ]
          },
          {
            "group": "Troubleshooting",
            "pages": [
              "1nspect/troubleshooting/common-issues"
            ]
          }
        ]
      },
      {
        "tab": "Mobile App",
        "groups": [
          {
            "group": "Coming Soon",
            "pages": [
              "mobile/overview"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Open App",
          "href": "https://app.1nspect.app",
          "icon": "arrow-up-right-from-square"
        },
        {
          "anchor": "Contact Support",
          "href": "mailto:support@1nspect.app",
          "icon": "envelope"
        }
      ]
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/1nspectapp"
    }
  },
  "contextual": {
    "options": ["copy", "view", "claude"]
  }
}
